#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#     "rich",
#     "scrapling[all]>=0.4",
# ]
# ///
"""
Mahoosuc Realty CLI - Sunday River / Bethel Maine ski properties

Uses scrapling to fetch IDXBroker listings.

Usage:
    mahoosuc search                    # All active listings in Bethel area
    mahoosuc search --beds 3           # 3+ bedrooms
    mahoosuc search --min-acres 1      # 1+ acres
"""

import argparse
import json
import re
import sys

from rich.console import Console
from rich.table import Table

console = Console()

# IDXBroker base URL for Mahoosuc Realty
BASE_URL = "https://mahoosucrealty.idxbroker.com/idx/search"

# Town codes for ski areas
TOWN_CODES = {
    "bethel": "144",
    "newry": "165",  # Sunday River
    "greenwood": "146",
}


def build_search_url(**filters) -> str:
    """Build IDXBroker search URL with filters."""
    params = []

    # Default to Bethel area (Sunday River)
    if filters.get("town"):
        town_code = TOWN_CODES.get(filters["town"].lower(), "144")
        params.append(f"ccz={town_code}")

    # Property type - single family only (exclude condos)
    params.append("a_propSubType[]=Single%20Family")

    # Status - active listings
    params.append("a_propStatus[]=Active")

    # Bedrooms
    if filters.get("min_beds"):
        params.append(f"bd={filters['min_beds']}")

    # Bathrooms
    if filters.get("min_baths"):
        params.append(f"ba={filters['min_baths']}")

    # Price
    if filters.get("min_price"):
        params.append(f"lp={filters['min_price']}")
    if filters.get("max_price"):
        params.append(f"hp={filters['max_price']}")

    # Acreage
    if filters.get("min_acres"):
        params.append(f"amin_acres={filters['min_acres']}")
    if filters.get("max_acres"):
        params.append(f"amax_acres={filters['max_acres']}")

    return f"{BASE_URL}?{'&'.join(params)}"


def search_with_scrapling(url: str, use_stealthy: bool = False) -> list[dict]:
    """Fetch IDXBroker results using scrapling."""
    try:
        if use_stealthy:
            from scrapling import StealthyFetcher
            fetcher = StealthyFetcher()
            page = fetcher.fetch(url, headless=True)
        else:
            from scrapling import Fetcher
            fetcher = Fetcher()
            page = fetcher.get(url)

        html = page.html_content
        listings = []

        # IDXBroker renders listings as HTML cards with various class patterns
        # Parse them from the HTML using regex patterns

        # Find all listing containers
        card_patterns = [
            r'<div[^>]*class="[^"]*IDX-resultsRow[^"]*"[^>]*>(.*?)</div>\s*</div>',
            r'<div[^>]*class="[^"]*propertyRow[^"]*"[^>]*>(.*?)</div>\s*</div>',
            r'<div[^>]*class="[^"]*listing-result[^"]*"[^>]*>(.*?)</div>\s*</div>',
        ]

        # Try to find JSON data in script tags (some IDXBroker sites embed this)
        json_match = re.search(r'var\s+(?:listingData|properties|results)\s*=\s*(\[.*?\]);', html, re.DOTALL)
        if json_match:
            try:
                return json.loads(json_match.group(1))
            except json.JSONDecodeError:
                pass

        # Extract from HTML cards
        # Look for common IDXBroker price patterns
        price_pattern = r'\$([0-9,]+)'
        address_pattern = r'<div[^>]*class="[^"]*(?:address|street)[^"]*"[^>]*>([^<]+)</div>'
        beds_pattern = r'(\d+)\s*(?:bed|br|bedroom)'
        baths_pattern = r'(\d+(?:\.\d+)?)\s*(?:bath|ba|bathroom)'
        acres_pattern = r'(\d+(?:\.\d+)?)\s*(?:acre|ac)'
        sqft_pattern = r'(\d+(?:,\d+)?)\s*(?:sqft|sf|sq\s*ft)'
        link_pattern = r'href="([^"]*idx/details/[^"]*)"'

        # Split by listing divs and extract data
        # This is a simplified extraction - IDXBroker layouts vary
        listing_blocks = re.split(r'<div[^>]*class="[^"]*(?:IDX-resultsRow|propertyRow|listing-result)[^"]*"', html)

        for block in listing_blocks[1:]:  # Skip first split (before any listing)
            listing = {}

            price_match = re.search(price_pattern, block)
            if price_match:
                listing['price'] = int(price_match.group(1).replace(',', ''))

            addr_match = re.search(address_pattern, block, re.IGNORECASE)
            if addr_match:
                listing['address'] = addr_match.group(1).strip()

            beds_match = re.search(beds_pattern, block, re.IGNORECASE)
            if beds_match:
                listing['beds'] = int(beds_match.group(1))

            baths_match = re.search(baths_pattern, block, re.IGNORECASE)
            if baths_match:
                listing['baths'] = float(baths_match.group(1))

            acres_match = re.search(acres_pattern, block, re.IGNORECASE)
            if acres_match:
                listing['acres'] = float(acres_match.group(1))

            sqft_match = re.search(sqft_pattern, block, re.IGNORECASE)
            if sqft_match:
                listing['sqft'] = int(sqft_match.group(1).replace(',', ''))

            link_match = re.search(link_pattern, block)
            if link_match:
                listing['url'] = link_match.group(1)
                if not listing['url'].startswith('http'):
                    listing['url'] = 'https://mahoosucrealty.idxbroker.com' + listing['url']

            if listing.get('price') or listing.get('address'):
                listings.append(listing)

        return listings

    except Exception as e:
        console.print(f"[red]Error: {e}[/red]")
        return []


def cmd_search(args):
    """Search for ski area listings."""
    filters = {}
    if args.town:
        filters["town"] = args.town
    if args.min_beds:
        filters["min_beds"] = args.min_beds
    if args.min_baths:
        filters["min_baths"] = args.min_baths
    if args.min_price:
        filters["min_price"] = args.min_price
    if args.max_price:
        filters["max_price"] = args.max_price
    if args.min_acres:
        filters["min_acres"] = args.min_acres

    url = build_search_url(**filters)
    console.print(f"[dim]Searching: {url}[/dim]")

    # Try tier 1 first
    listings = search_with_scrapling(url, use_stealthy=False)

    # If no results, try stealthy
    if not listings:
        console.print("[yellow]Tier 1 returned no results, trying Stealthy (Camoufox)...[/yellow]")
        listings = search_with_scrapling(url, use_stealthy=True)

    if args.json:
        print(json.dumps(listings, indent=2))
        return 0

    console.print(f"\n[bold]Sunday River / Bethel ME Homes[/bold] - {len(listings)} listings\n")

    if not listings:
        console.print("[yellow]No listings found. Try adjusting filters.[/yellow]")
        return 0

    table = Table()
    table.add_column("Price", style="green", justify="right")
    table.add_column("Beds", justify="center")
    table.add_column("Baths", justify="center")
    table.add_column("SqFt", justify="right")
    table.add_column("Acres", justify="right")
    table.add_column("Address", style="cyan")

    for l in listings[:20]:
        price_str = f"${l['price']:,}" if l.get('price') else "-"
        beds_str = str(l.get('beds', '-'))
        baths_str = str(l.get('baths', '-'))
        sqft_str = f"{l['sqft']:,}" if l.get('sqft') else "-"
        acres_str = f"{l['acres']:.2f}" if l.get('acres') else "-"
        addr = l.get('address', 'N/A')

        table.add_row(price_str, beds_str, baths_str, sqft_str, acres_str, addr[:40])

    console.print(table)

    if len(listings) > 20:
        console.print(f"\n[dim]Showing 20 of {len(listings)} results[/dim]")

    return 0


def main():
    parser = argparse.ArgumentParser(description="Mahoosuc Realty - Sunday River/Bethel ME (scrapling)")
    subparsers = parser.add_subparsers(dest="command", help="Commands")

    search_parser = subparsers.add_parser("search", help="Search listings")
    search_parser.add_argument("--town", help="Town name (bethel, newry, greenwood)")
    search_parser.add_argument("--min-beds", type=int, help="Minimum bedrooms")
    search_parser.add_argument("--min-baths", type=int, help="Minimum bathrooms")
    search_parser.add_argument("--min-price", type=int, help="Minimum price")
    search_parser.add_argument("--max-price", type=int, help="Maximum price")
    search_parser.add_argument("--min-acres", type=float, help="Minimum acreage")
    search_parser.add_argument("--json", action="store_true", help="Output JSON")
    search_parser.add_argument("--stealthy", action="store_true", help="Use Stealthy fetcher")

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        return 1

    if args.command == "search":
        return cmd_search(args)

    return 0


if __name__ == "__main__":
    sys.exit(main())
